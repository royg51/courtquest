# Database — Supabase PostgreSQL
# Get both connection strings from your Supabase project: Project Settings -> Database -> Connection string
# DATABASE_URL: the "Transaction" pooler connection (port 6543) — used by the app at runtime
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL: the direct connection (port 5432) — used only by `prisma migrate`
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=""
DIRECT_URL=""

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend (email)
RESEND_API_KEY=""
EMAIL_FROM="CourtQuest <noreply@courtquest.net>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin bootstrap (optional) — comma-separated emails to promote to ADMIN
# via `npm run db:seed`. Only ever updates an existing account; never
# creates one or invents credentials.
ADMIN_EMAILS=""

# Rate limiting (optional) — Upstash Redis, required in production (Vercel
# serverless functions can't share an in-memory counter across instances).
# Without these set, rate limiting falls back to an in-memory counter —
# fine for local dev, NOT safe for a real multi-instance deployment.
# Create a free database at https://console.upstash.com -> Redis -> Create
# Database, then copy the REST URL/token from its details page.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Rate limit overrides (optional) — sensible defaults are used if unset.
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
# RATE_LIMIT_SIGNUP_MAX=5
# RATE_LIMIT_SIGNUP_WINDOW_SECONDS=3600
# RATE_LIMIT_CHECKOUT_MAX=10
# RATE_LIMIT_CHECKOUT_WINDOW_SECONDS=60
# RATE_LIMIT_TOURNAMENT_CREATE_MAX=10
# RATE_LIMIT_TOURNAMENT_CREATE_WINDOW_SECONDS=3600
# RATE_LIMIT_REGISTRATION_MAX=20
# RATE_LIMIT_REGISTRATION_WINDOW_SECONDS=3600

# Sentry (optional) — error monitoring, client + server + edge. Without
# NEXT_PUBLIC_SENTRY_DSN set, Sentry doesn't initialize at all (no-op).
# Create a free project at https://sentry.io -> Next.js platform, then
# copy the DSN from Settings -> Projects -> [project] -> Client Keys (DSN).
# DSNs are safe to expose to the client (they only allow *sending* events,
# not reading data) — that's why this one is NEXT_PUBLIC_.
NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_DSN="" # optional: use a separate DSN for server-side events
#
# Only needed to upload source maps during build (so stack traces in
# Sentry show real file/line instead of minified code) — never exposed to
# the client. From Sentry: Settings -> Auth Tokens -> Create New Token
# (scopes: project:releases). SENTRY_ORG/SENTRY_PROJECT are the slugs shown
# in your project's URL.
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Analytics (optional) — Plausible, privacy-conscious, no cookies. Loads in
# production only, and only if set. Sign up at https://plausible.io (paid)
# or self-host (free) — see https://plausible.io/self-hosted-web-analytics.
# Set to your site's exact domain as registered in Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
