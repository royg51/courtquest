# Dependencies
node_modules/

# Build output
.next/
out/

# Environment variables — never commit these. Broad glob (not just
# .env/.env.local/.env.*.local) so .env.production, .env.development, etc.
# are covered too, regardless of whether Next.js itself would generate them.
.env*
!.env.example

# Database — globbed (not pinned to prisma/dev.db) since this is a SQLite
# leftover pattern from before the Postgres/Supabase migration; covers it
# wherever it ends up.
*.db
*.db-journal

# Logs
*.log
npm-debug.log*

# OS
.DS_Store

# Editor
.vscode/
.idea/

# Test
playwright-report/
test-results/
coverage/
tsconfig.tsbuildinfo
