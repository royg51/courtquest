// Prisma schema for CourtQuest 2.0
// PostgreSQL (Supabase), originally migrated from SQLite. Enum-like fields
// are intentionally kept as String — that's a carryover from SQLite (which
// has no native enum type) that we're preserving rather than "upgrading" to
// real Postgres enums, since callers throughout the app rely on the
// string-union types in types/index.ts rather than Prisma enum types. This
// keeps the migration purely a storage-engine swap, not a data-model change.
//
// Two connection strings, per Supabase + Prisma's recommended setup:
//   - DATABASE_URL: pooled (PgBouncer, port 6543) — used by the app at
//     runtime, where many short-lived serverless-style connections are
//     normal.
//   - DIRECT_URL: direct (port 5432) — used only by `prisma migrate`, since
//     migrations need a non-pooled connection (advisory locks, schema
//     changes don't work reliably through a transaction-mode pooler).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────────────────────────

// role: PLAYER | ORGANIZER | ADMIN
// skillLevel: BEGINNER | INTERMEDIATE | ADVANCE_INTERMEDIATE | ADVANCED
model User {
  id                   String       @id @default(cuid())
  email                String       @unique
  emailVerified        DateTime?
  name                 String
  phone                String?
  image                String?
  passwordHash         String?
  role                 String       @default("PLAYER")
  skillLevel           String?
  hasPlayedBefore      Boolean      @default(false)
  accounts             Account[]
  sessions             Session[]
  teamMembers          TeamMember[]
  permanentTeamMembers PermanentTeamMember[]
  tournamentsOrganized Tournament[]
  auditLogs            AuditLog[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// format: SINGLE_ELIM | DOUBLE_ELIM | ROUND_ROBIN | SWISS
// status: DRAFT | OPEN | IN_PROGRESS | COMPLETED | CANCELLED
model Tournament {
  id                   String     @id @default(cuid())
  slug                 String     @unique
  name                 String
  description          String?
  sport                String     @default("Pickleball")
  format               String     @default("SINGLE_ELIM")
  status               String     @default("DRAFT")
  organizerId          String
  organizer            User       @relation(fields: [organizerId], references: [id])
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime
  maxParticipants      Int
  minParticipants      Int        @default(4)
  teamSize             Int        @default(1)
  // entryType: SOLO | TEAM — drives teamSize (1 vs 2). Stored explicitly so
  // the create/edit UI and registration flow can branch on intent rather
  // than inferring it from teamSize.
  entryType            String     @default("SOLO")
  numberOfCourts       Int        @default(1)
  entryFeeCents        Int        @default(0)
  requiresPayment      Boolean    @default(false)
  venue                String?
  address              String?
  isPublic             Boolean    @default(true)
  // When true, people without an account can register (guest registration).
  // inviteCode is a short shareable "join with code" token; nullable until an
  // organizer generates one, unique so a code maps to exactly one tournament.
  allowGuestRegistration Boolean  @default(false)
  inviteCode           String?    @unique
  teams                Team[]
  bracket              Bracket?
  donations            Donation[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([createdAt])
}

// status: PENDING | CONFIRMED | WAITLISTED | WITHDRAWN
// paymentStatus: UNPAID | PAID | CASH | REFUNDED
model Team {
  id              String       @id @default(cuid())
  tournamentId    String
  tournament      Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name            String
  seed            Int?
  // Final standing once the tournament completes: 1 = champion, 2 = runner-up,
  // etc. Set by the format-specific completion logic (final-match winner for
  // elimination, standings order for round robin). Rankings read this instead
  // of inferring "champion/finalist" from bracket shape, so points are correct
  // regardless of format. Null until the tournament finishes.
  placement       Int?
  status          String       @default("PENDING")
  paymentStatus   String       @default("UNPAID")
  stripePaymentId String?
  // Set when this tournament registration was made on behalf of an existing
  // permanent team (its accepted roster copied in directly, no per-tournament
  // invite needed) rather than as a one-off, tournament-only team. SetNull so
  // deleting the permanent team later doesn't erase tournament history.
  permanentTeamId String?
  permanentTeam   PermanentTeam? @relation(fields: [permanentTeamId], references: [id], onDelete: SetNull)
  members         TeamMember[]
  matchesAsA      Match[]      @relation("TeamA")
  matchesAsB      Match[]      @relation("TeamB")
  matchesWon      Match[]      @relation("Winner")
  registeredAt    DateTime     @default(now())
}

// skillLevel: BEGINNER | INTERMEDIATE | ADVANCE_INTERMEDIATE | ADVANCED
// inviteStatus: PENDING | ACCEPTED | DECLINED. Defaults to ACCEPTED since
// every pre-existing path (the primary registrant, a guest partner someone
// else filled in) needs no acceptance step — PENDING/DECLINED only apply to
// the invite-by-email path (see lib/invites.ts), where inviteToken is set.
model TeamMember {
  id             String  @id @default(cuid())
  teamId         String
  team           Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?   @relation(fields: [userId], references: [id])
  isPrimary      Boolean @default(false)
  // Guest fields — for doubles partner who hasn't signed up yet
  guestName      String?
  guestEmail     String?
  guestPhone     String?
  skillLevel     String?
  waiverAccepted Boolean @default(false)
  inviteStatus   String  @default("ACCEPTED")
  inviteToken    String? @unique

  @@index([userId])
}

// A roster that exists independent of any one tournament — players create
// one once and reuse it to register for tournaments without re-inviting
// teammates each time (see Team.permanentTeamId). A one-off, tournament-only
// team (the original/default registration path) has no PermanentTeam at all.
model PermanentTeam {
  id        String                @id @default(cuid())
  name      String
  sport     String
  createdAt DateTime              @default(now())
  members   PermanentTeamMember[]
  teams     Team[]
}

// inviteStatus: PENDING | ACCEPTED | DECLINED — same invite-by-email flow as
// TeamMember, reused for permanent-team membership (see lib/invites.ts).
model PermanentTeamMember {
  id              String        @id @default(cuid())
  permanentTeamId String
  permanentTeam   PermanentTeam @relation(fields: [permanentTeamId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  isPrimary       Boolean       @default(false)
  guestEmail      String?
  inviteStatus    String        @default("ACCEPTED")
  inviteToken     String?       @unique
  joinedAt        DateTime      @default(now())

  @@index([userId])
}

model Bracket {
  id           String     @id @default(cuid())
  tournamentId String     @unique
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rounds       Round[]
  generatedAt  DateTime   @default(now())
}

model Round {
  id        String  @id @default(cuid())
  bracketId String
  bracket   Bracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  number    Int
  name      String
  matches   Match[]
}

// status: PENDING | IN_PROGRESS | COMPLETED | BYE
model Match {
  id           String    @id @default(cuid())
  roundId      String
  round        Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamAId      String?
  teamA        Team?     @relation("TeamA", fields: [teamAId], references: [id], onDelete: SetNull)
  teamBId      String?
  teamB        Team?     @relation("TeamB", fields: [teamBId], references: [id], onDelete: SetNull)
  scoreA       Int?
  scoreB       Int?
  winnerId     String?
  winner       Team?     @relation("Winner", fields: [winnerId], references: [id], onDelete: SetNull)
  status       String    @default("PENDING")
  // Left-to-right position within the round — SQLite/Postgres don't
  // guarantee insertion order on read, and bracket display needs one.
  position     Int       @default(0)
  courtNumber  Int?
  scheduledAt  DateTime?
  completedAt  DateTime?
  // Self-relation: which match does the winner advance to?
  nextMatchId  String?
  nextMatch    Match?    @relation("Advancement", fields: [nextMatchId], references: [id])
  fedByMatches Match[]   @relation("Advancement")
  isSlotA      Boolean   @default(true)
}

// Append-only audit trail for privileged/destructive actions (role changes,
// score overrides, bracket generation, tournament edits/deletes). Never
// updated or deleted in normal operation — it's the "who changed what, when,
// from what to what" record that makes the platform trustworthy and lets an
// admin investigate disputes or suspected tampering.
//
// action:     ROLE_CHANGED | TOURNAMENT_UPDATED | TOURNAMENT_DELETED |
//             MATCH_SCORE_UPDATED | BRACKET_GENERATED
// entityType: USER | TOURNAMENT | MATCH | BRACKET
model AuditLog {
  id         String   @id @default(cuid())
  // Who performed the action. Nullable + SetNull so deleting a user never
  // erases or blocks reading their historical actions (the log outlives the
  // actor); actorEmail keeps a human-readable record even after that.
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String?
  action     String
  entityType String
  entityId   String?
  // Before/after snapshots of just the changed fields (not whole rows) +
  // freeform context (e.g. tournamentId, ip). Json so each action can store
  // the shape that's meaningful for it without a column explosion.
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Donation {
  id              String      @id @default(cuid())
  amountCents     Int
  donorName       String?
  donorEmail      String?
  isAnonymous     Boolean     @default(false)
  // Unique so the Stripe webhook can be retried safely — Stripe redelivers
  // events on timeout/non-200, and without this a retry would insert a
  // second Donation row for the same payment.
  stripePaymentId String?     @unique
  message         String?
  // Nullable, not yet set by any UI — donations are a standalone, global
  // revenue stream today (see lib/tournaments.ts for why tournament revenue
  // is entry-fees-only and deliberately does NOT read this field). Reserved
  // for a future "donate to this tournament" flow.
  tournamentId    String?
  tournament      Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())
}
