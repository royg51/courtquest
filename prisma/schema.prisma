// Prisma schema for CourtQuest 2.0
// PostgreSQL (Supabase), originally migrated from SQLite. Enum-like fields
// are intentionally kept as String — that's a carryover from SQLite (which
// has no native enum type) that we're preserving rather than "upgrading" to
// real Postgres enums, since callers throughout the app rely on the
// string-union types in types/index.ts rather than Prisma enum types. This
// keeps the migration purely a storage-engine swap, not a data-model change.
//
// Two connection strings, per Supabase + Prisma's recommended setup:
//   - DATABASE_URL: pooled (PgBouncer, port 6543) — used by the app at
//     runtime, where many short-lived serverless-style connections are
//     normal.
//   - DIRECT_URL: direct (port 5432) — used only by `prisma migrate`, since
//     migrations need a non-pooled connection (advisory locks, schema
//     changes don't work reliably through a transaction-mode pooler).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────────────────────────

// role: PLAYER | ORGANIZER | ADMIN
// skillLevel: BEGINNER | INTERMEDIATE | ADVANCE_INTERMEDIATE | ADVANCED
model User {
  id                   String       @id @default(cuid())
  email                String       @unique
  emailVerified        DateTime?
  name                 String
  phone                String?
  image                String?
  passwordHash         String?
  role                 String       @default("PLAYER")
  skillLevel           String?
  hasPlayedBefore      Boolean      @default(false)
  accounts             Account[]
  sessions             Session[]
  teamMembers          TeamMember[]
  tournamentsOrganized Tournament[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

// format: SINGLE_ELIM | DOUBLE_ELIM | ROUND_ROBIN | SWISS
// status: DRAFT | OPEN | IN_PROGRESS | COMPLETED | CANCELLED
model Tournament {
  id                   String     @id @default(cuid())
  slug                 String     @unique
  name                 String
  description          String?
  sport                String     @default("Pickleball")
  format               String     @default("SINGLE_ELIM")
  status               String     @default("DRAFT")
  organizerId          String
  organizer            User       @relation(fields: [organizerId], references: [id])
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime
  maxParticipants      Int
  minParticipants      Int        @default(4)
  teamSize             Int        @default(1)
  entryFeeCents        Int        @default(0)
  requiresPayment      Boolean    @default(false)
  venue                String?
  address              String?
  isPublic             Boolean    @default(true)
  teams                Team[]
  bracket              Bracket?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

// status: PENDING | CONFIRMED | WAITLISTED | WITHDRAWN
// paymentStatus: UNPAID | PAID | CASH | REFUNDED
model Team {
  id              String       @id @default(cuid())
  tournamentId    String
  tournament      Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name            String
  seed            Int?
  status          String       @default("PENDING")
  paymentStatus   String       @default("UNPAID")
  stripePaymentId String?
  members         TeamMember[]
  matchesAsA      Match[]      @relation("TeamA")
  matchesAsB      Match[]      @relation("TeamB")
  matchesWon      Match[]      @relation("Winner")
  registeredAt    DateTime     @default(now())
}

// skillLevel: BEGINNER | INTERMEDIATE | ADVANCE_INTERMEDIATE | ADVANCED
model TeamMember {
  id             String   @id @default(cuid())
  teamId         String
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  isPrimary      Boolean  @default(false)
  // Guest fields — for doubles partner who hasn't signed up yet
  guestName      String?
  guestEmail     String?
  guestPhone     String?
  skillLevel     String?
  waiverAccepted Boolean  @default(false)
}

model Bracket {
  id           String     @id @default(cuid())
  tournamentId String     @unique
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rounds       Round[]
  generatedAt  DateTime   @default(now())
}

model Round {
  id        String  @id @default(cuid())
  bracketId String
  bracket   Bracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  number    Int
  name      String
  matches   Match[]
}

// status: PENDING | IN_PROGRESS | COMPLETED | BYE
model Match {
  id           String    @id @default(cuid())
  roundId      String
  round        Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamAId      String?
  teamA        Team?     @relation("TeamA", fields: [teamAId], references: [id])
  teamBId      String?
  teamB        Team?     @relation("TeamB", fields: [teamBId], references: [id])
  scoreA       Int?
  scoreB       Int?
  winnerId     String?
  winner       Team?     @relation("Winner", fields: [winnerId], references: [id])
  status       String    @default("PENDING")
  // Left-to-right position within the round — SQLite/Postgres don't
  // guarantee insertion order on read, and bracket display needs one.
  position     Int       @default(0)
  courtNumber  Int?
  scheduledAt  DateTime?
  completedAt  DateTime?
  // Self-relation: which match does the winner advance to?
  nextMatchId  String?
  nextMatch    Match?    @relation("Advancement", fields: [nextMatchId], references: [id])
  fedByMatches Match[]   @relation("Advancement")
  isSlotA      Boolean   @default(true)
}

model Donation {
  id              String   @id @default(cuid())
  amountCents     Int
  donorName       String?
  donorEmail      String?
  isAnonymous     Boolean  @default(false)
  // Unique so the Stripe webhook can be retried safely — Stripe redelivers
  // events on timeout/non-200, and without this a retry would insert a
  // second Donation row for the same payment.
  stripePaymentId String?  @unique
  message         String?
  createdAt       DateTime @default(now())
}
